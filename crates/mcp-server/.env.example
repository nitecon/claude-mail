# URL of the running gateway service
GATEWAY_URL=http://localhost:3000

# Must match GATEWAY_API_KEY in the gateway's .env
GATEWAY_API_KEY=

# Optional: auto-set identity on startup (skips the set_identity tool call)
# Useful for single-project installs
DEFAULT_PROJECT_IDENT=

# Timeout for gateway HTTP requests in milliseconds
GATEWAY_TIMEOUT_MS=5000

# Log level (written to stderr, not stdout, to avoid corrupting MCP stream)
RUST_LOG=info
